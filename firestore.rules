rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isProjectMember(project) {
      return request.auth != null
        && (
          request.auth.uid == project.ownerId
          || request.auth.uid in project.memberIds
        );
    }

    match /projects/{projectId} {
      allow read, update, delete: if isProjectMember(resource.data)
        || isProjectMember(request.resource.data);

      allow create: if request.auth != null
        && (
          request.auth.uid == request.resource.data.ownerId
          || request.auth.uid in request.resource.data.memberIds
        );
    }

    match /projects/{projectId}/{subcollection}/{documentId} {
      allow read, write: if isProjectMember(
        get(/databases/$(database)/documents/projects/$(projectId)).data
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
