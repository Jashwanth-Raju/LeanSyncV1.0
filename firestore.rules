rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isMember(data) {
      return request.auth != null
        && (
          request.auth.uid == data.get('ownerId', '')
          || request.auth.uid in data.get('memberIds', [])
        );
    }

    match /projects/{projectId} {
      allow read: if isMember(resource.data);

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;

      allow update, delete: if isMember(resource.data);
    }

    match /projects/{projectId}/{subcollection}/{documentId} {
      allow read, write: if isMember(
        get(/databases/$(database)/documents/projects/$(projectId)).data
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
